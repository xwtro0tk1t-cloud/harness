# Web Vulnerability Analyzer - CAI Framework Configuration
# ========================================================
#
# CAI uses OpenAI-compatible API. Three variables control the LLM connection:
#   OLLAMA_API_BASE  — API base URL (without /v1, auto-appended)
#   OPENAI_API_KEY   — API key (OLLAMA_API_KEY also works)
#   CAI_MODEL        — Model name sent to the API
#
# ┌──────────────────────────────────────────────────────────────────┐
# │  Provider        │ OLLAMA_API_BASE           │ CAI_MODEL         │
# ├──────────────────┼───────────────────────────┼───────────────────┤
# │  LiteLLM Proxy   │ https://your-proxy:4000   │ openai/xxx        │
# │  DeepSeek        │ https://api.deepseek.com  │ deepseek-chat     │
# │  OpenRouter      │ https://openrouter.ai/api │ anthropic/xxx     │
# │  OpenAI          │ https://api.openai.com    │ gpt-4o            │
# │  Local Ollama    │ http://localhost:11434     │ qwen2.5-coder:7b  │
# └──────────────────────────────────────────────────────────────────┘
#
# ⚠️  LiteLLM proxy 用户：模型名必须带 openai/ 前缀（让 litellm 走 OpenAI 兼容接口）
# ⚠️  直连 API 用户：模型名直接写，不要加任何前缀

# === LLM API 配置 ===

# 方式 1: LiteLLM Proxy
# OPENAI_API_KEY={{OPENAI_API_KEY}}
# OLLAMA_API_KEY={{OPENAI_API_KEY}}
# OLLAMA_API_BASE=https://{{LLM_API_BASE}}
# CAI_MODEL=ollama_cloud/claude-haiku-4-5-20251001

# 方式 2: DeepSeek 直连（当前使用）
# CAI 框架已内置 deepseek/ 前缀支持（line 2802 of openai_chatcompletions.py）
# litellm 原生支持 DeepSeek provider，无需 Anthropic 兼容层
DEEPSEEK_API_KEY={{DEEPSEEK_API_KEY}}
CAI_MODEL=deepseek/deepseek-chat

# 方式 3: 本地 Ollama（免费，功能受限）
# OPENAI_API_KEY=ollama
# OLLAMA_API_KEY=ollama
# OLLAMA_API_BASE=http://localhost:11434
# CAI_MODEL=qwen2.5-coder:7b

# === HexStrike 配置 ===
HEXSTRIKE_URL=http://localhost:8888
HEXSTRIKE_MODEL=anthropic/claude-sonnet-4-6

# === CAI 运行参数 ===
CAI_SAFE_MODE=true
CAI_GUARDRAILS=false
CAI_MAX_TURNS=200
CAI_TIMEOUT=1800
LITELLM_TIMEOUT=120
OPENAI_AGENTS_DISABLE_TRACING=true

# === 扫描配置 ===
SCAN_MODE=focused
DEBUG=false
MAX_CONCURRENT_SCANS=3
SCAN_TIMEOUT=600
